# Copy to .env. main.py reads runtime settings only from this file.
# ===== OpenAI =====
OPENAI_API_KEY=your_openai_api_key_here

# ===== Session Defaults =====
LANGUAGE_LEVEL=B1

# ===== Voice Input =====
PAUSE_THRESHOLD=2.5
PHRASE_TIME_LIMIT=60
# 0 disables the hard cap for a single spoken reply
# 0 disables auto-exit on long silence before the next utterance
SESSION_IDLE_TIMEOUT=45

# ===== Teacher Voice =====
TTS_SPEED=0.8
TTS_VOLUME=0.9
TTS_MAX_CHUNK_WORDS=5
SMALL_PAUSE_MS=220
CLAUSE_PAUSE_MS=420
SENTENCE_PAUSE_MS=720
