# ===== OpenAI API =====
OPENAI_API_KEY=your_openai_api_key_here

# ===== Google Gemini API =====
GEMINI_API_KEY=your_gemini_api_key_here

# ===== ElevenLabs API (опционально) =====
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ===== Конфигурация микрофона =====
PAUSE_THRESHOLD=2.5
PHRASE_TIME_LIMIT=30

# ===== Конфигурация TTS =====
TTS_SPEED=0.8
TTS_SERVICE=pyttsx3  # pyttsx3 или openai

# ===== Конфигурация LLM =====
LLM_MODEL=gemini  # gemini или openai
LANGUAGE_LEVEL=B1  # A2 или B1

# ===== Серверные настройки =====
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=true

